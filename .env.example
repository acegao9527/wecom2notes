# WeCom 企业微信配置
WECOM_TOKEN=your_wecom_token
WECOM_CORP_ID=your_corp_id
WECOM_ENCODING_AES_KEY=your_encoding_aes_key
WECOM_APP_SECRET=your_app_secret
WECOM_PRIVATE_KEY_PATH=private_key.pem
HOST_PRIVATE_KEY_PATH=./private_key.pem

# 可选：过滤机器人自己发的消息
WECOM_BOT_USERID=your_bot_userid

# 可选：首次补拉消息时使用的最大偏移量
WECOM_OFFSET_MAX=0

# SQLite 数据库
SQLITE_DB_PATH=data/wecom2notes.db

# 腾讯云 COS 配置（用于上传图片/文件到云存储）
# 从腾讯云控制台获取: https://console.cloud.tencent.com/cos
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-shanghai
COS_BUCKET=your-cos-bucket
COS_BASE_URL=https://your-cos-bucket.cos.ap-shanghai.myqcloud.com
COS_ROOT_DIR=wecom2notes

# 可选：附件存储 local / cos / s3-compatible
ASSET_STORAGE_BACKEND=local
ASSET_LOCAL_PATH=data/assets

# 可选：Obsidian/Markdown 目标
OBSIDIAN_VAULT_PATH=
OBSIDIAN_BASE_DIR=WeCom
OBSIDIAN_MODE=daily
MARKDOWN_NOTES_PATH=
MARKDOWN_BASE_DIR=WeCom
MARKDOWN_MODE=daily

# 可选：JSON 路由配置文件
NOTES_ROUTES_CONFIG=config/routes.json

# 应用端口
APP_PORT=8001

# 日志级别
LOG_LEVEL=INFO
